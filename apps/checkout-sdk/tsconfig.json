{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "bundler",
        "noEmit": true,
        "jsx": "react-jsx",
        "outDir": "dist",
        "rootDir": "src",
        "lib": [
            "DOM",
            "DOM.Iterable",
            "ESNext"
        ],
        "composite": false
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
